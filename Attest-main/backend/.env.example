ATTEST_SIGNING_KEY_PEM="-----BEGIN PRIVATE KEY-----\nPASTE_YOUR_ED25519_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
ATTEST_DATABASE_URL=postgresql://username:password@ep-xyz.aws.neon.tech/neondb?sslmode=require
ATTEST_GROQ_API_KEY=your-groq-api-key
ATTEST_GROQ_MODEL=llama-3.3-70b-versatile
ATTEST_ALLOWED_ORIGINS=http://localhost:5173,https://your-project.vercel.app
ATTEST_PUBLIC_KEY_PATH=keys/public_key.pem
ATTEST_DATA_DIR=data
ATTEST_CHUNK_SIZE=500
ATTEST_CHUNK_OVERLAP=50
ATTEST_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ATTEST_TOP_K=3
ATTEST_QUARANTINE_ON_MISMATCH=true
ATTEST_MONITOR_INTERVAL_SECONDS=900
